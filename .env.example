# OpenAI-compatible default config.
# Review, vision, and file upload will use these values unless separately overridden.
OPENAI_API_KEY=your-openai-compatible-key
OPENAI_BASE_URL=https://your-openai-compatible-endpoint.example/v1

# Vision model: reads images/PDF/files and extracts drawing facts.
# If blank, it defaults to QUOTE_REVIEW_MODEL with the review/OpenAI-compatible endpoint.
QUOTE_VISION_MODEL=
QUOTE_VISION_BASE_URL=
QUOTE_VISION_API_KEY=
# auto: try /v1/responses first, then fall back to /v1/chat/completions if blocked.
# responses: only /v1/responses. chat: only /v1/chat/completions.
QUOTE_VISION_ENDPOINT=auto
QUOTE_VISION_STREAM=true

# Work model: text-only routing, costing reasoning, and report generation.
# This can be Mimo/TokenPlan even when it does not support image input.
QUOTE_WORK_MODEL=mimo-tokenplan-model-name
QUOTE_WORK_BASE_URL=https://your-tokenplan-endpoint.example/v1
QUOTE_WORK_API_KEY=your-tokenplan-api-key

# Review model: checks whether the generated quote can be used as final output.
QUOTE_REVIEW_MODEL=gpt-5.5
QUOTE_REVIEW_BASE_URL=
QUOTE_REVIEW_API_KEY=
# responses: call /v1/responses directly. chat: use OpenAI-compatible chat completions.
QUOTE_REVIEW_ENDPOINT=responses
QUOTE_REVIEW_STREAM=true

# Optional file upload endpoint. Defaults to OPENAI_BASE_URL / OPENAI_API_KEY.
QUOTE_FILE_BASE_URL=
QUOTE_FILE_API_KEY=

# Disable OpenAI tracing when using non-official OpenAI-compatible providers.
QUOTE_DISABLE_TRACING=true
QUOTE_MODEL_TIMEOUT_SECONDS=90
QUOTE_MODEL_RETRY_ATTEMPTS=2

# Excel output enhancement: split assembly drawings/BOM tables into detailed cost-object rows.
QUOTE_EXCEL_OUTPUT_ENABLED=true
QUOTE_BOM_DECOMPOSITION_ENABLED=true
QUOTE_EXCEL_IMAGE_REGIONS_ENABLED=true
QUOTE_EXCEL_IMAGE_REGION_MAX_ASSETS=40
QUOTE_ROW_IMAGE_REGIONS_ENABLED=true
QUOTE_ROW_IMAGE_MAX_SOURCE_IMAGES=14
QUOTE_ROW_IMAGE_STREAM=true
QUOTE_BOM_REGION_IMAGES_ENABLED=true
QUOTE_BOM_REGION_IMAGE_MAX_FILES=12
QUOTE_BOM_STREAM=true
QUOTE_EXCEL_STREAM=true
QUOTE_EXCEL_AUDIT_ENABLED=true
QUOTE_EXCEL_AUDIT_AGENT_ENABLED=true
QUOTE_EXCEL_AUDIT_MAX_RETRIES=1
QUOTE_EXCEL_AUDIT_STREAM=true

# RAG knowledge retrieval.
# provider=pgvector uses QUOTE_DATABASE_URL + PostgreSQL pgvector.
# provider=dify calls: {QUOTE_RAG_BASE_URL}/datasets/{QUOTE_RAG_DATASET_ID}/retrieve
# provider=custom calls: {QUOTE_RAG_BASE_URL}/retrieval with a Dify-style external knowledge payload.
QUOTE_RAG_ENABLED=false
QUOTE_RAG_PROVIDER=pgvector
QUOTE_RAG_BASE_URL=https://api.dify.ai/v1
QUOTE_RAG_API_KEY=
QUOTE_RAG_DATASET_ID=
QUOTE_RAG_TABLE=quote_rag_documents
QUOTE_RAG_TOP_K=5
QUOTE_RAG_SCORE_THRESHOLD=0
QUOTE_RAG_MAX_CONTEXT_CHARS=2400
QUOTE_RAG_STATIC_FALLBACK=true
QUOTE_RAG_TIMEOUT_SECONDS=12
QUOTE_RAG_FEEDBACK_SYNC_ENABLED=true
# Feedback can be retrieved by the row-image agent and also kept as a general feedback corpus.
QUOTE_RAG_FEEDBACK_STAGES=row_image,feedback
QUOTE_RAG_FEEDBACK_REPORT_MAX_CHARS=3200
QUOTE_RAG_FEEDBACK_JSON_MAX_CHARS=3200
QUOTE_RAG_FEEDBACK_MAX_ROWS=40

# RAG embedding model.
# provider=hash works locally without an embedding API. provider=openai uses an OpenAI-compatible /embeddings endpoint.
QUOTE_RAG_EMBEDDING_PROVIDER=hash
QUOTE_RAG_HASH_DIMENSIONS=384
QUOTE_RAG_EMBEDDING_MODEL=text-embedding-3-small
QUOTE_RAG_EMBEDDING_BASE_URL=
QUOTE_RAG_EMBEDDING_API_KEY=
QUOTE_RAG_EMBEDDING_ENDPOINT=
QUOTE_RAG_EMBEDDING_MAX_CHARS=6000
QUOTE_RAG_EMBEDDING_TIMEOUT_SECONDS=30

# PDF preprocessing and page-level vision extraction.
QUOTE_PDF_RENDER_DPI=200
QUOTE_PDF_MAX_PAGES=20
QUOTE_PDF_RENDER_WORKERS=2
QUOTE_PAGE_VISION_CONCURRENCY=2

# Asset classification before recognition: separates technical drawings, real photos, CAD renders,
# BOM tables, title blocks, and notes so downstream agents choose the right evidence.
QUOTE_ASSET_CLASSIFIER_ENABLED=true
QUOTE_ASSET_CLASSIFIER_MAX_IMAGES=18
QUOTE_ASSET_CLASSIFIER_STREAM=true

# Runtime paths.
# Local development can keep relative paths here; they are resolved from the project root.
# Production should store the env file at /etc/quote-agent-assistant/.env and data at
# /var/lib/quote-agent-assistant/data.
QUOTE_DATA_DIR=data
QUOTE_INBOX_DIR=inbox
QUOTE_OUTBOX_DIR=outbox

# Public service settings.

# PostgreSQL login/history settings.
# When QUOTE_DATABASE_URL is set, web login/session auth is enabled.
QUOTE_DATABASE_URL=postgresql://quote_agent:change-db-password@127.0.0.1:5432/quote_agent
QUOTE_AUTH_REQUIRED=true
QUOTE_ADMIN_USERNAME=admin
QUOTE_ADMIN_PASSWORD=change-admin-password
QUOTE_ADMIN_RESET_PASSWORD=false
QUOTE_SESSION_TTL_DAYS=7
QUOTE_COOKIE_SECURE=true

# Feishu login. Keep disabled until the Feishu app credentials are configured.
QUOTE_PUBLIC_BASE_URL=https://cost.inferhub.tech
QUOTE_FEISHU_LOGIN_ENABLED=false
QUOTE_FEISHU_APP_ID=
QUOTE_FEISHU_APP_SECRET=
QUOTE_FEISHU_REDIRECT_URI=https://cost.inferhub.tech/auth/feishu/callback
QUOTE_FEISHU_DEFAULT_ROLE=user
QUOTE_FEISHU_SCOPES=
QUOTE_FEISHU_TIMEOUT_SECONDS=12
